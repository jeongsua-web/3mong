# env 템플릿 (실제 값 파일은 .env.development / .env.production)
# 개인 오버라이드가 필요하면 .env.local 또는 .env.<mode>.local 사용 (git 무시됨)

# API 서버 주소 (HTTPS 도메인이 생기면 https://api.example.com/api/v1 형태로 교체)
VITE_API_BASE_URL=http://<host>:8080/api/v1

# 인증 우회 플래그. 로컬 개발 편의용으로만 true, 커밋/운영 값은 항상 false
VITE_SKIP_AUTH=false
