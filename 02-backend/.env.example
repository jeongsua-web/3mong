DB_USER=fluento
DB_PASSWORD=your_strong_password_here

AWS_REGION=ap-northeast-2
AWS_COGNITO_USER_POOL_ID=ap-northeast-2_LZObF20b3
AWS_COGNITO_CLIENT_ID=<your_app_client_id>

# AWS Bedrock — EC2 IAM Role로 자동 인증되므로 별도 키 불필요
# 로컬 개발 시 AWS CLI 프로필 설정 필요: aws configure
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# 운영은 비워두면 default 프로필 (JWT 인증 활성화)
# SPRING_PROFILES_ACTIVE=dev
